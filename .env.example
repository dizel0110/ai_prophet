# === TELEGRAM API (только для HF Spaces) ===
# Cloudflare Worker URL для обхода блокировки api.telegram.org
# Пример: https://telegram-proxy.xxxx.workers.dev
TELEGRAM_API_URL=

# === ADMIN ACCESS ===
# Chat ID владельцев админ-панели (через запятую, без пробелов)
# Как узнать ID: напиши /id боту или используй @userinfobot
# Пример: ADMIN_IDS=123456789,987654321
ADMIN_IDS=
# Команда /give_access @username в боте — добавит пользователя с этим username

# === DEMO API (Kaggle capstone security demo) ===
# API key for /api/demo/* endpoints. Sent via X-API-Key header.
# If empty, endpoints are unprotected (judges can test freely).
DEMO_API_KEY=

